<!-- pages/login/login.wxml -->
<view class="login-page">
  <!-- 装饰背景 -->
  <view class="bg-decoration">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

    <!-- 登录内容 -->
    <view class="login-content">
    <view class="login-header">
      <view class="logo-area">
        <text class="logo-icon">💼</text>
      </view>
      <text class="welcome-title">欢迎来到展瑞</text>
      <text class="welcome-subtitle">人力资源管理系统</text>
    </view>

    <view class="login-form">
      <!-- 微信手机号快捷登录 -->
      <view class="wechat-phone-login">
        <button
          class="btn-wechat-phone"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
          disabled="{{logging}}"
        >
          <text class="wechat-icon">💬</text>
          <text class="wechat-text">{{logging ? '登录中...' : '微信手机号快捷登录'}}</text>
        </button>

        <view class="agreement">
          <text>登录即表示同意</text>
          <text class="link">《用户协议》</text>
          <text>和</text>
          <text class="link">《隐私政策》</text>
        </view>
      </view>
    </view>



    <!-- 底部信息 -->
    <view class="footer">
      <text class="footer-text">客服电话：13815736023</text>
    </view>
  </view>

  <!-- 全局客服浮动按钮 -->
  <global-service-btn 
    show="{{true}}"
    show-label="{{true}}"
  />
</view>
