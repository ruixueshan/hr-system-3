.onboard-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f2f7ff 0%, #f7f8fa 40%, #ffffff 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-card,
.info-card,
.login-card,
.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(35, 55, 90, 0.08);
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #183153;
}

.hero-subtitle,
.card-desc {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.6;
}

.card-title,
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #243b53;
  margin-bottom: 20rpx;
}

.section-title {
  margin-top: 12rpx;
}

.info-row,
.form-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.info-row:last-child,
.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  flex-shrink: 0;
  color: #52606d;
  font-size: 28rpx;
}

.value {
  flex: 1;
  color: #102a43;
  font-size: 28rpx;
  text-align: right;
}

.input,
.date-picker,
.picker {
  flex: 1;
  color: #102a43;
  font-size: 28rpx;
  min-height: 44rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.picker-arrow {
  color: #98a2b3;
  font-size: 34rpx;
  line-height: 1;
}

.settlement-item {
  align-items: flex-start;
}

.settlement-radio-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
}

.settlement-radio {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #102a43;
  font-size: 28rpx;
}

.btn-primary,
.btn-submit {
  width: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 88rpx;
  height: 88rpx;
  border: none;
}

.footer {
  padding: 12rpx 0 36rpx;
}
