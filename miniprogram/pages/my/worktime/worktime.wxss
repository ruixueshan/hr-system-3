/* pages/my/worktime/worktime.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.month-selector {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #111;
  background: #fff;
  padding: 16rpx;
  border-radius: 12rpx;
}

.company-picker {
  background: #fff;
}

.picker-icon {
  font-size: 40rpx;
}

.picker-text {
  font-size: 32rpx;
  font-weight: bold;
  color: inherit;
}

.picker-arrow {
  font-size: 24rpx;
}

.stats-card {
  display: flex;
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.warn-bar {
  margin: 0 20rpx 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  color: #d46b08;
  font-size: 24rpx;
  line-height: 34rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  background: #f0f0f0;
  margin: 0 20rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #999;
}

.calendar-container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.calendar-card,
.day-detail-card {
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.calendar-card {
  padding: 24rpx;
}

.calendar-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}

.calendar-subtitle {
  font-size: 24rpx;
  color: #888;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-row {
  margin-bottom: 12rpx;
}

.week-cell {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 40rpx;
}

.calendar-grid {
  gap: 8rpx;
}

.calendar-day {
  height: 104rpx;
  border-radius: 8rpx;
  background: #f7f8fa;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  padding: 8rpx 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.calendar-day-muted {
  opacity: 0;
  pointer-events: none;
}

.calendar-day-filled {
  background: #fff1f1;
  border-color: #f3b2b2;
}

.calendar-day-approved {
  background: #e6f9ef;
  border-color: #7fd9a7;
}

.calendar-day-today {
  border-color: #07c160;
}

.calendar-day-selected {
  background: #2f6fed;
  border-color: #2f6fed;
  box-shadow: 0 8rpx 18rpx rgba(47,111,237,0.25);
}

.day-number {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  line-height: 30rpx;
}

.day-hours {
  font-size: 24rpx;
  font-weight: 700;
  color: #07a455;
  line-height: 28rpx;
}

.calendar-day-filled .day-hours {
  color: #c53030;
}

.calendar-day-approved .day-hours {
  color: #0f9d58;
}

.day-shift {
  font-size: 18rpx;
  color: #777;
  line-height: 22rpx;
}

.calendar-day-selected .day-number,
.calendar-day-selected .day-hours,
.calendar-day-selected .day-shift {
  color: #fff;
}

.day-detail-card {
  padding: 24rpx;
}

.day-detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.mini-add-btn-disabled {
  opacity: 0.45;
}

.day-detail-date,
.day-detail-tip {
  display: block;
}

.day-detail-date {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 6rpx;
}

.day-detail-tip {
  font-size: 24rpx;
  color: #888;
}

.mini-add-btn {
  width: 128rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  padding: 0;
  border-radius: 30rpx;
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
}

.mini-add-btn::after {
  border: 0;
}

.day-empty {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #aaa;
  font-size: 28rpx;
  background: #fafafa;
  border-radius: 8rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-row {
  background: #fafafa;
  border-radius: 8rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-hours {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f6fed;
}

.detail-company,
.detail-time {
  font-size: 24rpx;
  color: #666;
}

.record-row {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  display: grid;
  grid-template-columns: 1.4fr 1.6fr auto;
  align-items: center;
  column-gap: 16rpx;
}

.row-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.row-left .date {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.row-left .weekday {
  font-size: 24rpx;
  color: #888;
}

.row-left .company {
  font-size: 24rpx;
  color: #555;
}

.row-mid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #333;
}

.row-mid .hours {
  font-size: 34rpx;
  font-weight: 700;
  color: #667eea;
}

.row-mid .time-range {
  font-size: 24rpx;
  color: #666;
}

.row-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.shift-tag {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.shift-tag.shift-day {
  background: #e8f4ff;
  color: #1890ff;
}
.shift-tag.shift-night {
  background: #f0e6ff;
  color: #764ba2;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}
.status-tag.status-approved {
  background: #e8f9ef;
  color: #07c160;
}
.status-tag.status-rejected {
  background: #fff0f0;
  color: #e54545;
}
.status-tag.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.shift-selector {
  flex: 1;
  display: flex;
  gap: 16rpx;
}
.shift-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f6f6f6;
  font-size: 28rpx;
  color: #666;
}
.shift-btn.shift-active {
  background: #667eea;
  color: #fff;
  font-weight: 600;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 20rpx rgba(7,193,96,0.35);
  z-index: 10;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 999;
}

.sheet {
  width: 100%;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 0;
  box-sizing: border-box;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: margin-bottom 0.2s ease;
}

.sheet-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  padding: 32rpx 32rpx 24rpx 32rpx;
  flex-shrink: 0;
}

.sheet-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.sheet-content {
  padding: 0;
}

.sheet-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.sheet-row .label {
  width: 180rpx;
  color: #333;
}

.sheet-row .input,
.sheet-row .picker {
  flex: 1;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}
.sheet-row .input.tall {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.sheet-readonly-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.sheet-readonly-row .label {
  width: 180rpx;
  color: #333;
}

.readonly-value {
  flex: 1;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  color: #555;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #14c67a 0%, #07b86a 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(7, 193, 96, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  line-height: 1;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  color: #344054;
  font-size: 30rpx;
  font-weight: 600;
  border: 1rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  line-height: 1;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-shrink: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eef1f4;
  background: #fff;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.btn-row .half {
  flex: 1;
  margin-top: 0;
}

.btn-primary::after,
.btn-secondary::after {
  border: none;
}
