<!--pages/job-detail/detail.wxml-->
<view class="detail-container">
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else class="content">
    <!-- 头部信息 -->
    <view class="header-section">
      <view class="job-title">{{job.title}}</view>
      <view class="job-tags">
        <text class="tag tag-salary">{{job.salary_range}}</text>
        <text class="tag tag-location">{{job.location}}</text>
        <text class="tag tag-experience">{{job.experience}}</text>
      </view>
      <view class="job-meta">
        <text class="meta-item">{{job.company_name || '展瑞'}}</text>
        <text class="meta-item">{{job.education}}</text>
        <text class="meta-item">{{job.recruit_count}}人</text>
        <text class="meta-item" wx:if="{{job.work_time}}">{{job.work_time}}</text>
      </view>
    </view>

    <!-- 职位描述 -->
    <view class="section">
      <view class="section-title">职位描述</view>
      <view class="section-content">
        <text class="content-text">{{job.description}}</text>
      </view>
    </view>

    <!-- 工作内容 -->
    <view class="section" wx:if="{{job.work_content}}">
      <view class="section-title">工作内容</view>
      <view class="section-content">
        <text class="content-text">{{job.work_content}}</text>
      </view>
    </view>

    <!-- 工作时间 -->
    <view class="section" wx:if="{{job.work_time}}">
      <view class="section-title">工作时间</view>
      <view class="section-content">
        <text class="content-text">{{job.work_time}}</text>
      </view>
    </view>

    <!-- 详细要求 -->
    <view class="section">
      <view class="section-title">详细要求</view>
      <view class="section-content">
        <view class="detail-grid">
          <view class="detail-item" wx:if="{{job.department}}">
            <text class="detail-label">所属部门：</text>
            <text class="detail-value">{{job.department}}</text>
          </view>
          <view class="detail-item" wx:if="{{job.gender && job.gender !== '不限'}}">
            <text class="detail-label">性别要求：</text>
            <text class="detail-value">{{job.gender}}</text>
          </view>
          <view class="detail-item" wx:if="{{job.age_min || job.age_max}}">
            <text class="detail-label">年龄要求：</text>
            <text class="detail-value">
              <text wx:if="{{job.age_min}}">{{job.age_min}}岁</text>
              <text wx:if="{{job.age_min && job.age_max}}">-</text>
              <text wx:if="{{job.age_max}}">{{job.age_max}}岁</text>
              <text wx:if="{{!job.age_min && !job.age_max}}">不限</text>
            </text>
          </view>
          <view class="detail-item">
            <text class="detail-label">学历要求：</text>
            <text class="detail-value">{{job.education}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">经验要求：</text>
            <text class="detail-value">{{job.experience}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">招聘人数：</text>
            <text class="detail-value">{{job.vacancies}}人（已招{{job.recruited}}人）</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 职位要求 -->
    <view class="section" wx:if="{{job.requirements}}">
      <view class="section-title">职位要求</view>
      <view class="section-content">
        <text class="content-text">{{job.requirements}}</text>
      </view>
    </view>

    <!-- 福利待遇 -->
    <view class="section" wx:if="{{job.benefits && job.benefits.length > 0}}">
      <view class="section-title">福利待遇</view>
      <view class="section-content">
        <view class="benefits-list">
          <text 
            class="benefit-tag" 
            wx:for="{{job.benefits}}" 
            wx:key="index"
          >{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 工作地点 -->
    <view class="section" wx:if="{{job.address}}">
      <view class="section-title">工作地点</view>
      <view class="section-content">
        <text class="content-text">{{job.address}}</text>
      </view>
    </view>

    <!-- 岗位状态 -->
      <view class="section">
        <view class="section-title">岗位状态</view>
        <view class="section-content">
          <view class="status-grid">
            <view class="status-item">
              <text class="status-label">招聘状态：</text>
              <text class="status-value">
                <text class="status-badge {{job.is_recruiting ? 'status-active' : 'status-inactive'}}">
                  {{job.is_recruiting ? '招聘中' : '已暂停'}}
                </text>
              </text>
            </view>
            <view class="status-item" wx:if="{{job.shift_type}}">
              <text class="status-label">班制：</text>
              <text class="status-value">
                {{ job.shift_type === 'day' ? '长白班' : (job.shift_type === 'two_shift' ? '两班倒' : job.shift_type) }}
              </text>
            </view>
            <view class="status-item">
              <text class="status-label">岗位状态：</text>
              <text class="status-value">{{job.status || '正常'}}</text>
            </view>
          <view class="status-item">
            <text class="status-label">发布时间：</text>
            <text class="status-value">{{job.created_at}}</text>
          </view>
          <view class="status-item">
            <text class="status-label">工作类型：</text>
            <text class="status-value">{{job.job_type}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="section">
      <view class="section-title">联系方式</view>
      <view class="section-content">
        <view class="contact-item">
          <text class="contact-label">联系人：</text>
          <text class="contact-value">{{job.contact_person || 'HR'}}</text>
        </view>
        <view class="contact-item">
          <text class="contact-label">电话：</text>
          <text class="contact-value">{{job.contact_phone || '请联系HR'}}</text>
        </view>
        <view class="contact-item" wx:if="{{job.company_address}}">
          <text class="contact-label">公司地址：</text>
          <text class="contact-value">{{job.company_address}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="footer-actions">
      <button 
        class="btn-contact" 
        bindtap="handleContact"
      >
        <text class="btn-icon">咨询</text>
        <text>客服</text>
      </button>
      <button 
        class="btn-apply {{applied ? 'btn-applied' : ''}}" 
        bindtap="handleApply"
        disabled="{{applied}}"
      >
        {{applied ? '已申请' : '立即申请'}}
      </button>
    </view>

    <!-- 申请表单弹窗 -->
    <view wx:if="{{showDatePicker}}" class="apply-modal">
      <view class="modal-mask" bindtap="hideApplyForm"></view>
      <view class="modal-content">
        <view class="modal-header">
          <text class="modal-title">选择期望面试时间</text>
          <text class="modal-close" bindtap="hideApplyForm">×</text>
        </view>
        <view class="modal-body">
          <picker 
            mode="date" 
            value="{{expectedInterviewTime}}" 
            start="{{startDate}}"
            end="{{endDate}}"
            bindchange="onDateChange"
          >
            <view class="date-picker">
              <text class="date-label">面试日期：</text>
              <text class="date-value">{{expectedInterviewTime || '请选择日期'}}</text>
              <text class="date-arrow">▼</text>
            </view>
          </picker>
          <view class="modal-hint">请选择今天或未来的日期</view>
        </view>
        <view class="modal-footer">
          <button class="btn-cancel" bindtap="hideApplyForm">取消</button>
          <button class="btn-confirm" bindtap="confirmApply">确认申请</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 全局客服浮动按钮 -->
  <global-service-btn 
    show="{{true}}"
    show-label="{{true}}"
  />

  <!-- 登录弹窗 -->
  <login-sheet 
    visible="{{showLoginSheet}}"
    bind:close="onLoginClose"
    bind:login-success="onLoginSuccess"
  />

  <canvas
    canvas-id="sharePosterCanvas"
    id="sharePosterCanvas"
    class="share-poster-canvas"
  ></canvas>
</view>
