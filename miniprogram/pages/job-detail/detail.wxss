/* pages/job-detail/detail.wxss */
.detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.header-section {
  background: #fff;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.job-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.job-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-salary {
  background: #fff0f0;
  color: #ff4d4f;
}

.tag-location {
  background: #e6f7ff;
  color: #1890ff;
}

.tag-experience {
  background: #f6ffed;
  color: #52c41a;
}

.job-meta {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 26rpx;
  color: #666;
}

.section {
  background: #fff;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

.section-content {
  line-height: 1.8;
}

.content-text {
  font-size: 30rpx;
  color: #666;
  white-space: pre-wrap;
}

.benefits-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.benefit-tag {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  color: #667eea;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.contact-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.contact-label {
  color: #999;
  flex-shrink: 0;
}

.contact-value {
  color: #333;
  margin-left: 10rpx;
}

.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.btn-contact {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn-contact::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-apply {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-apply::after {
  border: none;
}

.btn-applied {
  background: #d9d9d9;
  color: #999;
}

/* 新增样式 */
.detail-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  font-size: 28rpx;
  line-height: 1.6;
}

.detail-label {
  color: #999;
  flex-shrink: 0;
  width: 160rpx;
}

.detail-value {
  color: #333;
  flex: 1;
}

.status-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.status-item {
  display: flex;
  font-size: 28rpx;
  line-height: 1.6;
}

.status-label {
  color: #999;
  flex-shrink: 0;
  width: 160rpx;
}

.status-value {
  color: #333;
  flex: 1;
  display: flex;
  align-items: center;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-active {
  background: #e6f7ff;
  color: #1890ff;
}

.share-poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750px;
  height: 960px;
  pointer-events: none;
  opacity: 0;
}

.status-inactive {
  background: #f5f5f5;
  color: #999;
}

/* 申请表单弹窗样式 */
.apply-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  border-bottom: 2rpx solid #f5f5f5;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  font-size: 50rpx;
  color: #999;
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
}

.modal-body {
  padding: 40rpx;
}

.date-picker {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
}

.date-label {
  font-size: 30rpx;
  color: #333;
  margin-right: 20rpx;
}

.date-value {
  font-size: 30rpx;
  color: #666;
  flex: 1;
}

.date-arrow {
  font-size: 24rpx;
  color: #999;
}

.modal-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  text-align: center;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #f5f5f5;
}

.btn-cancel {
  flex: 1;
  height: 100rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 0;
  font-size: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 0;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm::after {
  border: none;
}
