.apply-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0A1A2F 0%, #1a2744 100%);
  padding: 30rpx;
}

.hero-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  display: block;
  line-height: 1.5;
}

.info-card, .form-card {
  background: rgba(255,255,255,0.05);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(0,249,255,0.2);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #00F9FF;
  margin-bottom: 20rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
}

.value {
  color: white;
  font-size: 28rpx;
}

.card-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 20rpx;
}

.submit-status {
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid transparent;
}

.submit-status-info {
  background: rgba(102, 126, 234, 0.16);
  border-color: rgba(102, 126, 234, 0.35);
}

.submit-status-success {
  background: rgba(32, 201, 151, 0.14);
  border-color: rgba(32, 201, 151, 0.35);
}

.submit-status-error {
  background: rgba(255, 107, 107, 0.16);
  border-color: rgba(255, 107, 107, 0.4);
}

.submit-status-text {
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.5;
}

.form-item {
  margin-bottom: 25rpx;
}

.form-item .label {
  display: block;
  margin-bottom: 10rpx;
  color: rgba(255,255,255,0.7);
}

.input {
  background: rgba(255,255,255,0.1);
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 30rpx;
  color: white;
  border: 1rpx solid rgba(0,249,255,0.2);
}

.btn-submit {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-submit-disabled {
  opacity: 0.72;
}
