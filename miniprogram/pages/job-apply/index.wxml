<view class="apply-page">
  <view class="hero-card">
    <text class="hero-title">扫码报名登记</text>
    <text class="hero-subtitle">完成信息填写后，系统会自动创建候选人档案并绑定推荐关系。</text>
  </view>

  <view class="info-card" wx:if="{{qrInfo}}">
    <view class="card-title">报名信息</view>
    <view class="info-row">
      <text class="label">企业</text>
      <text class="value">{{qrInfo.company_name || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="label">岗位</text>
      <text class="value">{{qrInfo.job_name || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="label">面试时间</text>
      <text class="value">{{qrInfo.interview_time || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="label">推荐人</text>
      <text class="value">{{qrInfo.creator_name || '-'}}</text>
    </view>
  </view>

  <view class="form-card">
    <view class="card-title">填写报名信息</view>
    <text class="card-desc">请填写真实信息，以便后续面试联系</text>

    <view class="submit-status submit-status-{{submitHintType}}" wx:if="{{submitHint}}">
      <text class="submit-status-text">{{submitHint}}</text>
    </view>

    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" value="{{form.real_name}}" data-field="real_name" bindinput="onInput" placeholder="请输入真实姓名" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" value="{{form.phone}}" data-field="phone" bindinput="onInput" type="number" maxlength="11" placeholder="请输入手机号" />
    </view>

    <view class="form-item">
      <text class="label">身份证号</text>
      <input class="input" value="{{form.id_card}}" data-field="id_card" bindinput="onInput" maxlength="18" placeholder="请输入18位身份证号" />
    </view>
  </view>

  <view class="footer">
    <button class="btn-submit {{loading ? 'btn-submit-disabled' : ''}}" bindtap="handleSubmit" loading="{{submitting}}" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交报名'}}
    </button>
  </view>
</view>
