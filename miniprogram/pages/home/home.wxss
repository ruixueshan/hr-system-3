/* pages/home/home.wxss - 分销团队首页（复古未来主义风格） */

/* 基础变量 */
page {
  --color-primary: #0A1A2F;
  --color-accent-1: #00F9FF;
  --color-accent-2: #FF6B35;
  --color-neutral-1: #8E9EA8;
  --color-neutral-2: #3A3A5D;
  --color-bg: #0A0F1C;
  --color-text: #FFFFFF;
  --color-text-secondary: #8E9EA8;
  --grid-color: rgba(0, 249, 255, 0.1);
}

.distributor-home {
  min-height: 100vh;
  background-color: var(--color-bg);
  color: var(--color-text);
  position: relative;
  overflow-x: hidden;
  font-family: 'Rajdhani', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 网格背景 */
.grid-background {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  background-image: 
    linear-gradient(var(--grid-color) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  background-position: -20rpx -20rpx;
  opacity: 0.3;
  pointer-events: none;
}

.main-content {
  position: relative;
  z-index: 1;
  padding: 30rpx 24rpx;
}

/* 头部标题区 */
.header-section {
  margin-bottom: 30rpx;
  position: relative;
}

.title-container {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.main-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 2rpx;
  background: linear-gradient(90deg, var(--color-accent-1), var(--color-accent-2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 30rpx rgba(0, 249, 255, 0.3);
}

.sub-title {
  font-family: 'Share Tech Mono', monospace;
  font-size: 20rpx;
  color: var(--color-accent-1);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  opacity: 0.8;
}

.title-decoration {
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
}

.decoration-line {
  position: absolute;
  background: linear-gradient(90deg, transparent, var(--color-accent-1));
}

.line-1 {
  top: 20rpx;
  right: 0;
  width: 100rpx;
  height: 2rpx;
  transform: rotate(45deg);
}

.line-2 {
  top: 40rpx;
  right: 20rpx;
  width: 80rpx;
  height: 2rpx;
  transform: rotate(-45deg);
}

.decoration-dot {
  position: absolute;
  top: 80rpx;
  right: 60rpx;
  width: 12rpx;
  height: 12rpx;
  background-color: var(--color-accent-2);
  border-radius: 50%;
  box-shadow: 0 0 20rpx var(--color-accent-2);
}

/* 吸引文案区 */
.attraction-section {
  margin-bottom: 24rpx;
}

/* 未登录用户申请入口 */
.application-entry-section {
  margin-bottom: 24rpx;
}

.application-entry-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-neutral-2));
  border-radius: 24rpx;
  padding: 30rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0, 249, 255, 0.2);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    0 0 0 1rpx rgba(0, 249, 255, 0.1),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.05);
}

.entry-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  display: block;
}

.entry-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.entry-stats {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.entry-stat {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.1);
}

.entry-stat-number {
  font-family: 'Share Tech Mono', monospace;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-accent-1);
  display: block;
  margin-bottom: 8rpx;
}

.entry-stat-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
}

.entry-apply-btn {
  background: linear-gradient(135deg, var(--color-accent-2), #FF8C42);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  transition: all 0.3s;
  margin-bottom: 16rpx;
}

.entry-apply-btn:active {
  transform: translateY(2rpx);
  opacity: 0.9;
}

.entry-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.attraction-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-neutral-2));
  border-radius: 24rpx;
  padding: 30rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0, 249, 255, 0.2);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    0 0 0 1rpx rgba(0, 249, 255, 0.1),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.05);
}

.card-glow {
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(0, 249, 255, 0.1) 0%, transparent 70%);
  z-index: 0;
}

.card-content {
  position: relative;
  z-index: 1;
}

.icon-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.icon-circle {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--color-accent-1), var(--color-accent-2));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 40rpx;
}

.icon-image {
  width: 80rpx;
  height: 80rpx;
  display: block;
}

.attraction-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  display: block;
}

.attraction-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.1);
}

.stat-number {
  font-family: 'Share Tech Mono', monospace;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-accent-1);
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
}

/* 用户状态区 */
.status-section {
  margin-bottom: 24rpx;
}

.status-card {
  background: rgba(10, 26, 47, 0.8);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.2);
  backdrop-filter: blur(10rpx);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.avatar-section {
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-accent-1);
}

.avatar-glow {
  position: absolute;
  top: -5rpx;
  left: -5rpx;
  right: -5rpx;
  bottom: -5rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--color-accent-1) 0%, transparent 70%);
  opacity: 0.3;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.5; }
}

.user-details {
  flex: 1;
}

.user-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
}

.user-phone {
  font-family: 'Share Tech Mono', monospace;
  font-size: 24rpx;
  color: var(--color-accent-1);
  display: block;
  margin-bottom: 16rpx;
}

.role-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.agent-tag {
  background: linear-gradient(135deg, var(--color-accent-1), var(--color-neutral-1));
  color: var(--color-primary);
}

.candidate-tag {
  background: rgba(255, 107, 53, 0.2);
  color: var(--color-accent-2);
  border: 1rpx solid var(--color-accent-2);
}

/* 申请状态 */
.application-status {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(142, 158, 168, 0.2);
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.status-indicator {
  font-family: 'Share Tech Mono', monospace;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-indicator.pending {
  background: rgba(255, 107, 53, 0.2);
  color: var(--color-accent-2);
  border: 1rpx solid var(--color-accent-2);
}

.status-indicator.approved {
  background: rgba(0, 249, 255, 0.2);
  color: var(--color-accent-1);
  border: 1rpx solid var(--color-accent-1);
}

.status-indicator.none {
  background: rgba(142, 158, 168, 0.2);
  color: var(--color-neutral-1);
  border: 1rpx solid var(--color-neutral-1);
}

.apply-btn {
  background: linear-gradient(135deg, var(--color-accent-2), #FF8C42);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  transition: all 0.3s;
}

.apply-btn.disabled {
  background: linear-gradient(135deg, #3A3A5D, #4A4A6D);
  color: var(--color-text-secondary);
  opacity: 0.7;
}

.apply-btn:not(.disabled):active {
  transform: translateY(2rpx);
  opacity: 0.9;
}

.status-hint {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.referral-tip {
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: rgba(0, 249, 255, 0.12);
  color: var(--color-accent-1);
  font-size: 24rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.22);
}

/* 已认证代理入口 */
.agent-portal {
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(0, 249, 255, 0.2);
}

.portal-header {
  margin-bottom: 20rpx;
}

.portal-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.portal-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.portal-icon {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
}

.portal-subtitle {
  font-size: 24rpx;
  color: var(--color-accent-1);
  display: block;
}

.portal-stats {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.portal-stat {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: rgba(0, 249, 255, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.2);
}

.portal-stat-number {
  font-family: 'Share Tech Mono', monospace;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-accent-1);
  display: block;
  margin-bottom: 8rpx;
}

.portal-stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
}

.recruitment-hub-btn {
  background: linear-gradient(135deg, var(--color-accent-1), #00CCFF);
  color: var(--color-primary);
  border: none;
  border-radius: 16rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  width: 100%;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.recruitment-hub-btn:active {
  transform: translateY(2rpx);
  opacity: 0.9;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
}

.quick-action-btn {
  flex: 1;
  background: rgba(255, 107, 53, 0.1);
  color: var(--color-accent-2);
  border: 1rpx solid var(--color-accent-2);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 24rpx;
  text-align: center;
  transition: all 0.3s;
}

.quick-action-btn:active {
  background: rgba(255, 107, 53, 0.2);
  transform: translateY(2rpx);
}

/* 功能特色区 */
.features-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.feature-item {
  background: rgba(10, 26, 47, 0.6);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(142, 158, 168, 0.2);
  transition: all 0.3s;
}

.feature-item:active {
  transform: translateY(-4rpx);
  border-color: var(--color-accent-1);
}

.feature-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 12rpx;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

.feature-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  display: block;
}

/* 底部信息 */
.footer-section {
  text-align: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(142, 158, 168, 0.2);
}

.footer-text {
  font-family: 'Orbitron', sans-serif;
  font-size: 20rpx;
  color: var(--color-text);
  display: block;
  margin-bottom: 12rpx;
}

.footer-contact {
  font-family: 'Share Tech Mono', monospace;
  font-size: 20rpx;
  color: var(--color-accent-1);
  display: block;
  margin-bottom: 12rpx;
}

.footer-copyright {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  display: block;
}

/* 加载中 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 15, 28, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  text-align: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(0, 249, 255, 0.2);
  border-top-color: var(--color-accent-1);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 32rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-accent-1);
}

/* 管理视图样式 */
.manage-container {
  min-height: 100vh;
  position: relative;
  z-index: 1;
  padding: 30rpx 24rpx;
}

.manage-container .header {
  display: flex;
  align-items: center;
  padding: 20rpx 0 30rpx;
  position: relative;
}

.manage-container .back-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(0, 249, 255, 0.1);
  border-radius: 40rpx;
  color: var(--color-accent-1);
  font-size: 28rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.3);
}

.manage-container .back-btn:active {
  background: rgba(0, 249, 255, 0.2);
}

.manage-container .back-icon {
  margin-right: 10rpx;
  font-size: 32rpx;
}

.manage-container .title {
  flex: 1;
  text-align: center;
  color: var(--color-text);
  font-size: 40rpx;
  font-weight: 700;
  font-family: 'Orbitron', sans-serif;
}

.manage-container .content {
  background: rgba(10, 26, 47, 0.8);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 20rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.2);
  backdrop-filter: blur(10rpx);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    0 0 0 1rpx rgba(0, 249, 255, 0.1),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.05);
}

.manage-container .card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-neutral-2));
  border-radius: 20rpx;
  padding: 40rpx;
  color: var(--color-text);
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.2);
}

.manage-container .card-title {
  font-size: 36rpx;
  font-weight: 600;
  font-family: 'Orbitron', sans-serif;
  margin-bottom: 10rpx;
  color: var(--color-accent-1);
}

.manage-container .card-subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  opacity: 0.9;
}

.manage-container .promo-card {
  margin-bottom: 32rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: rgba(3, 12, 24, 0.72);
  border: 1rpx solid rgba(0, 249, 255, 0.18);
}

.manage-container .promo-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.manage-container .promo-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.manage-container .promo-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.manage-container .promo-btn {
  margin: 0;
  padding: 0 28rpx;
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-accent-1), #00c8ff);
  color: #071322;
  font-size: 24rpx;
  font-weight: 700;
}

.manage-container .promo-body {
  margin-top: 24rpx;
}

.manage-container .promo-image {
  width: 320rpx;
  height: 320rpx;
  display: block;
  margin: 0 auto 20rpx;
  border-radius: 20rpx;
  background: #fff;
  padding: 16rpx;
  box-sizing: border-box;
}

.manage-container .promo-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.manage-container .promo-line,
.manage-container .promo-empty {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  word-break: break-all;
}

.manage-container .promo-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.manage-container .promo-secondary-btn {
  flex: 1;
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background: rgba(0, 249, 255, 0.1);
  border: 1rpx solid rgba(0, 249, 255, 0.25);
  color: var(--color-accent-1);
  font-size: 24rpx;
}

.manage-container .menu-list {
  margin-bottom: 40rpx;
}

.manage-container .menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid rgba(142, 158, 168, 0.2);
  transition: all 0.3s;
}

.manage-container .menu-item:active {
  background: rgba(0, 249, 255, 0.05);
  transform: translateX(4rpx);
}

.manage-container .menu-item:last-child {
  border-bottom: none;
}

.manage-container .menu-icon {
  width: 80rpx;
  height: 80rpx;
  text-align: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.manage-container .menu-content {
  flex: 1;
}

.manage-container .menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 5rpx;
}

.manage-container .menu-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.manage-container .menu-arrow {
  font-size: 40rpx;
  color: var(--color-accent-1);
  margin-left: 20rpx;
  opacity: 0.7;
}

.manage-container .tips {
  background: rgba(10, 26, 47, 0.6);
  border-radius: 15rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  border-left: 6rpx solid var(--color-accent-1);
}

.manage-container .tips text {
  color: var(--color-accent-1);
  font-weight: 600;
}

/* 入职码弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
}

.onboard-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-primary), var(--color-neutral-2));
  border-radius: 30rpx 30rpx 0 0;
  z-index: 1001;
  max-height: 85vh;
  overflow-y: auto;
  border: 1rpx solid rgba(0, 249, 255, 0.3);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.5);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 249, 255, 0.2);
}

.modal-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-accent-1);
}

.modal-close {
  font-size: 50rpx;
  color: var(--color-text-secondary);
  line-height: 1;
  padding: 0 10rpx;
}

.modal-content {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 15rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--color-text);
  border: 1rpx solid rgba(0, 249, 255, 0.2);
}

.modal-input {
  box-sizing: border-box;
  width: 100%;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--color-text);
  border: 1rpx solid rgba(0, 249, 255, 0.2);
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--color-accent-1);
}

.qr-section {
  margin-top: 40rpx;
}

.btn-generate {
  background: linear-gradient(135deg, var(--color-accent-1), #00CCFF);
  color: var(--color-primary);
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 24rpx;
  border: none;
  width: 100%;
}

.btn-generate[disabled] {
  background: var(--color-neutral-2);
  color: var(--color-text-secondary);
}

.qr-display {
  margin-top: 20rpx;
}

.qr-info {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.15);
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  color: var(--color-text-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  color: var(--color-text);
  flex: 1;
}

.info-value.code {
  font-family: monospace;
  font-size: 26rpx;
  color: var(--color-accent-1);
  word-break: break-all;
}

.qr-image-wrapper {
  display: flex;
  justify-content: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.qr-image {
  width: 400rpx;
  height: 400rpx;
}

.qr-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.btn-save {
  flex: 1;
  background: linear-gradient(135deg, var(--color-accent-1), #00CCFF);
  color: var(--color-primary);
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx;
  border: none;
}

.btn-again {
  flex: 1;
  background: rgba(255, 255, 255, 0.1);
  color: var(--color-text);
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(0, 249, 255, 0.3);
}

.qr-tips {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 20rpx;
  background: rgba(255, 107, 53, 0.1);
  border-radius: 12rpx;
  line-height: 1.5;
  border: 1rpx solid rgba(255, 107, 53, 0.3);
}

/* 分销二维码弹窗样式 */
.agent-qr-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-primary), var(--color-neutral-2));
  border-radius: 30rpx 30rpx 0 0;
  z-index: 1001;
  max-height: 85vh;
  overflow-y: auto;
  border: 1rpx solid rgba(0, 249, 255, 0.3);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.5);
}

.agent-qr-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  padding: 20rpx 0;
  line-height: 1.5;
}
