.checkin-page {
  min-height: 100vh;
  background: #0a1a2f;
  padding: 30rpx;
}

.hero-card {
  background: linear-gradient(135deg, #667eea 0%, #2f8f83 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  line-height: 1.5;
}

.info-card,
.form-card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 18rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #55e6c1;
  display: block;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 28rpx;
  flex-shrink: 0;
}

.value {
  color: #ffffff;
  font-size: 28rpx;
  text-align: right;
  word-break: break-all;
}

.submit-status {
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid transparent;
}

.submit-status-info {
  background: rgba(102, 126, 234, 0.16);
  border-color: rgba(102, 126, 234, 0.35);
}

.submit-status-success {
  background: rgba(85, 230, 193, 0.14);
  border-color: rgba(85, 230, 193, 0.35);
}

.submit-status-error {
  background: rgba(255, 107, 107, 0.16);
  border-color: rgba(255, 107, 107, 0.4);
}

.submit-status-text {
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.5;
}

.login-block {
  padding: 22rpx;
  margin-bottom: 26rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.login-tip {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.5;
  display: block;
  margin-bottom: 18rpx;
}

.btn-login {
  background: #55e6c1;
  color: #0a1a2f;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-item {
  margin-bottom: 25rpx;
}

.form-item .label {
  display: block;
  margin-bottom: 10rpx;
}

.input {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 30rpx;
  color: #ffffff;
  border: 1rpx solid rgba(85, 230, 193, 0.22);
}

.btn-submit {
  background: linear-gradient(135deg, #667eea 0%, #2f8f83 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.btn-submit-disabled {
  opacity: 0.62;
}
