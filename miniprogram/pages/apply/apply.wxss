/* pages/apply/apply.wxss */
.apply-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.job-card {
  background: linear-gradient(135deg, #2C3E50 0%, #34495E 100%);
  padding: 50rpx 40rpx;
  margin-bottom: 20rpx;
}

.job-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.job-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-item {
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 申请状态卡片 */
.status-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 40rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.status-reapply {
  border-left: 8rpx solid #E74C3C;
}

.status-active {
  border-left: 8rpx solid #3498DB;
}

.status-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.status-content {
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
}

.status-text {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.status-value {
  font-size: 28rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 15rpx;
}

.status-value.pending {
  background: #FFF3CD;
  color: #856404;
}

.status-value.reviewing {
  background: #D1ECF1;
  color: #0C5460;
}

.status-value.interviewing {
  background: #D4EDDA;
  color: #155724;
}

.status-value.hired {
  background: #D4EDDA;
  color: #155724;
}

.status-value.rejected {
  background: #F8D7DA;
  color: #721C24;
}

.status-value.cancelled {
  background: #E2E3E5;
  color: #383D41;
}

.status-value.expired {
  background: #E2E3E5;
  color: #383D41;
}

.status-time {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.status-hint {
  font-size: 26rpx;
  color: #E74C3C;
  background: #FDEDED;
  padding: 15rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.form-container {
  padding: 20rpx 40rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #2C3E50;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.required .label::before {
  content: '*';
  color: #E74C3C;
  margin-right: 8rpx;
}

.form-item .label {
  flex-shrink: 0;
  width: 180rpx;
  font-size: 30rpx;
  color: #333;
}

.form-item .input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.form-item .picker {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.form-item.vertical {
  flex-direction: column;
  align-items: stretch;
}

.form-item.vertical .label {
  width: auto;
  margin-bottom: 20rpx;
}

.form-item .textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 咨询区域 */
.consult-section {
  background: linear-gradient(135deg, rgba(8, 18, 36, 0.96) 0%, rgba(32, 51, 95, 0.94) 100%);
  border-radius: 26rpx;
  padding: 34rpx 30rpx;
  margin-top: 30rpx;
  border: 2rpx solid rgba(79, 189, 255, 0.18);
  box-shadow: 0 12rpx 30rpx rgba(25, 48, 88, 0.18);
}

.consult-hint {
  font-size: 28rpx;
  color: #dbe8ff;
  margin-bottom: 24rpx;
  text-align: center;
}

.btn-consult {
  background: linear-gradient(135deg, #12d9ff 0%, #617cff 100%);
  color: #fff;
  border-radius: 28rpx;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  border: none;
  padding: 20rpx 24rpx;
  margin: 0 auto;
  box-shadow: 0 16rpx 28rpx rgba(47, 101, 255, 0.24);
}

.btn-consult::after {
  border: none;
}

.consult-image {
  width: 92rpx;
  height: 92rpx;
  flex-shrink: 0;
}

.consult-copy {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.btn-consult .consult-text {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.consult-subtext {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

/* 操作按钮 */
.btn-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-submit {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #2C3E50 0%, #34495E 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.btn-submit.btn-disabled {
  background: linear-gradient(135deg, #95A5A6 0%, #7F8C8D 100%);
  color: #BDC3C7;
}

.btn-submit::after {
  border: none;
}

/* 全局客服浮动按钮 */
.global-service-btn {
  position: fixed;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
  box-shadow: 0 8rpx 30rpx rgba(231, 76, 60, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  transition: transform 0.2s;
}

.global-service-btn:active {
  transform: scale(0.95);
}

.service-btn-inner {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-icon {
  font-size: 40rpx;
  color: #fff;
}
