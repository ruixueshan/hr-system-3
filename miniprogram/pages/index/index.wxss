/* pages/index/index.wxss */
.index-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.search-bar {
  background: #fff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.join-group-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0 4rpx;
}
.join-group-bar cell {
  width: 100%;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  padding-left: 16rpx;
  border-left: 1rpx solid #e0e0e0;
}

.banner-section {
  padding: 20rpx 0;
}

.banner-swiper {
  height: 300rpx;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 40rpx 30rpx 30rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.filter-section {
  background: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.filter-tabs {
  display: flex;
  gap: 30rpx;
}

.filter-tab {
  font-size: 28rpx;
  color: #666;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.job-list {
  padding: 20rpx 30rpx;
}

.job-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, #fffdf8 100%);
  border-radius: 30rpx;
  padding: 28rpx 32rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 36rpx rgba(33, 66, 26, 0.08);
  overflow: hidden;
  position: relative;
}

.poster-card::after {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -70rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(63, 120, 46, 0.06);
}

.poster-card::before {
  content: '';
  position: absolute;
  right: 130rpx;
  bottom: 86rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(250, 191, 0, 0.08);
}

.poster-theme-green {
  border: 1rpx solid rgba(47, 94, 34, 0.08);
}

.poster-theme-orange {
  border: 1rpx solid rgba(222, 126, 40, 0.10);
}

.poster-theme-orange::after {
  background: rgba(232, 145, 46, 0.08);
}

.poster-theme-orange::before {
  background: rgba(255, 202, 113, 0.14);
}

.poster-theme-teal {
  border: 1rpx solid rgba(35, 124, 118, 0.10);
}

.poster-theme-teal::after {
  background: rgba(47, 153, 145, 0.08);
}

.poster-theme-teal::before {
  background: rgba(138, 215, 208, 0.18);
}

.poster-theme-blue {
  border: 1rpx solid rgba(60, 98, 184, 0.10);
}

.poster-theme-blue::after {
  background: rgba(72, 111, 205, 0.08);
}

.poster-theme-blue::before {
  background: rgba(138, 170, 238, 0.18);
}

.poster-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.poster-branding {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.poster-brand {
  font-size: 24rpx;
  color: #2c4e22;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.poster-company {
  font-size: 22rpx;
  color: #92a087;
  letter-spacing: 1rpx;
}

.poster-theme-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 260rpx;
  padding: 12rpx 22rpx;
  background: #eef5e9;
  color: #47613a;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.poster-heading {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.poster-title {
  font-size: 70rpx;
  line-height: 1.04;
  font-weight: 700;
  color: #285b1f;
  text-align: center;
  letter-spacing: 3rpx;
}

.poster-year {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #24451d;
  letter-spacing: 4rpx;
}

.poster-hero {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
  position: relative;
  z-index: 1;
}

.poster-copy {
  flex: 1;
  min-width: 0;
}

.poster-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f251d;
  margin-bottom: 18rpx;
}

.poster-copy-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.poster-copy-item {
  display: flex;
  flex-wrap: nowrap;
  align-items: flex-start;
  gap: 8rpx;
}

.poster-copy-label {
  font-size: 24rpx;
  color: #333;
  font-weight: 700;
  line-height: 1.6;
  flex-shrink: 0;
}

.poster-copy-value {
  min-width: 0;
  font-size: 24rpx;
  color: #404040;
  line-height: 1.6;
}

.poster-art {
  width: 220rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.poster-art-frame {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-art-image {
  width: 190rpx;
  height: 190rpx;
}

.poster-art-caption {
  padding: 8rpx 18rpx;
  background: rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #50694b;
}

.poster-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-top: 26rpx;
  position: relative;
  z-index: 1;
}

.poster-badge-circle {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: #8e1f08;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(142, 31, 8, 0.18);
}

.poster-badge-title {
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
}

.poster-badge-year {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.poster-summary {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.poster-highlights {
  display: flex;
  flex-wrap: nowrap;
  gap: 14rpx;
  color: #6b6b6b;
  font-size: 22rpx;
  overflow: hidden;
}

.poster-highlight {
  flex-shrink: 0;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poster-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 20rpx;
  align-items: center;
}

.poster-salary {
  font-size: 34rpx;
  color: #0f8f4d;
  font-weight: 700;
}

.poster-update {
  font-size: 24rpx;
  color: #999;
}

.poster-cta {
  flex-shrink: 0;
  min-width: 178rpx;
  padding: 24rpx 26rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #1ccc67 0%, #10b854 100%);
  color: #fff;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 28rpx rgba(16, 184, 84, 0.18);
}

.poster-theme-orange .poster-title {
  color: #935719;
}

.poster-theme-orange .poster-year,
.poster-theme-orange .poster-brand {
  color: #79420c;
}

.poster-theme-orange .poster-theme-chip {
  background: #fff2e5;
  color: #925113;
}

.poster-theme-orange .poster-salary {
  color: #db7d16;
}

.poster-theme-teal .poster-title {
  color: #1f6f69;
}

.poster-theme-teal .poster-year,
.poster-theme-teal .poster-brand {
  color: #165c57;
}

.poster-theme-teal .poster-theme-chip {
  background: #e6f7f5;
  color: #22756f;
}

.poster-theme-teal .poster-salary {
  color: #11817b;
}

.poster-theme-blue .poster-title {
  color: #325ea8;
}

.poster-theme-blue .poster-year,
.poster-theme-blue .poster-brand {
  color: #284b84;
}

.poster-theme-blue .poster-theme-chip {
  background: #ecf3ff;
  color: #3a5d9e;
}

.poster-theme-blue .poster-salary {
  color: #3766ba;
}

@media (max-width: 420px) {
  .poster-title {
    font-size: 56rpx;
  }

  .poster-hero {
    gap: 12rpx;
  }

  .poster-art {
    width: 180rpx;
  }

  .poster-art-frame {
    width: 160rpx;
    height: 160rpx;
  }

  .poster-art-image {
    width: 150rpx;
    height: 150rpx;
  }

  .poster-bottom {
    align-items: flex-end;
  }

  .poster-cta {
    min-width: 160rpx;
    padding: 22rpx 20rpx;
  }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #999;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0 12rpx;
}

.loading-spinner.small {
  width: 28rpx;
  height: 28rpx;
  border-width: 3rpx;
}

.loading-more-text {
  font-size: 24rpx;
  color: #999;
}

.end-text {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #999;
}
